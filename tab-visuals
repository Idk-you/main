        if obj:IsA("Clouds") then obj.Enabled = not s end
    end
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        for _, obj in ipairs(terrain:GetChildren()) do
            if obj:IsA("Clouds") then obj.Enabled = not s end
        end
    end
end, Default = false})

applyGrassRemoval = function(enable)
    local terrain = workspace:FindFirstChildOfClass("Terrain")

    local function _zeroGrass(t)
        if not t then return end
        pcall(function() sethiddenproperty(t, "Decoration", false) end)
        pcall(function() sethiddenproperty(t, "GrassLength",  0)   end)
    end
    local function _restoreGrass(t)
        if not t then return end
        pcall(function() sethiddenproperty(t, "Decoration", true) end)
        pcall(function() sethiddenproperty(t, "GrassLength", 2)   end)
    end
    local function _zeroMaterial()
        pcall(function()
            local ms = game:GetService("MaterialService")
            if ms and ms:FindFirstChild("GrassTerrain") then
                ms.GrassTerrain.StudsPerTile = 9999999
            end
        end)
    end
    local function _restoreMaterial()
        pcall(function()
            local ms = game:GetService("MaterialService")
            if ms and ms:FindFirstChild("GrassTerrain") then
                ms.GrassTerrain.StudsPerTile = 8
            end
        end)
    end

    -- disconnect any old watcher first
    if BrzS._grassConn then BrzS._grassConn:Disconnect(); BrzS._grassConn = nil end
    if BrzS._grassCharConn then BrzS._grassCharConn:Disconnect(); BrzS._grassCharConn = nil end

    if enable then
        -- apply immediately to current terrain
        _zeroGrass(terrain)
        _zeroMaterial()

        -- watch for terrain being re-added (map changes, teleports)
        BrzS._grassConn = workspace.DescendantAdded:Connect(function(obj)
            if obj:IsA("Terrain") then
                task.wait() -- one frame so it's parented fully
                _zeroGrass(obj)
                _zeroMaterial()
            end
        end)
        -- re-apply on respawn in case terrain is reloaded per-character
        BrzS._grassCharConn = player.CharacterAdded:Connect(function()
            task.wait(0.5)
            _zeroGrass(workspace:FindFirstChildOfClass("Terrain"))
        end)
    else
        _restoreGrass(terrain)
        _restoreMaterial()
    end
end

WldSection:Toggle({Title = "remove grass", Flag = "WldNoGrass", Default = false, Callback = function(s)
    ModS.noGrass = s
    applyGrassRemoval(s)
end})
WldSection:Toggle({Title = "no leaves", Flag = "WldNoLeaves", Default = false, Callback = function(s)
