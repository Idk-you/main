local CFG_FOLDER = "ExchangeHook/Configs"
local function cfgEnsure()
    pcall(function()
        if not isfolder("ExchangeHook")        then makefolder("ExchangeHook")        end
        if not isfolder(CFG_FOLDER)            then makefolder(CFG_FOLDER)            end
    end)
end

local function cfgList()
    local files = {}
    pcall(function()
        cfgEnsure()
        for _, f in ipairs(listfiles(CFG_FOLDER)) do

            local name = f:gsub(".*/",""):gsub("%.json$","")
            if name ~= "" then files[#files+1] = name end
        end
    end)
    return files
end

local function cfgSave(name)
    if not name or name == "" then return false end
    name = name:gsub("[^%w%-%_%. ]",""):sub(1,32)
    if name == "" then return false end
    cfgEnsure()
    local snap = {}
    for k, v in pairs(Library.Flags) do
        local t = type(v)
        if t == "boolean" or t == "number" or t == "string" then
            snap[k] = v
        end
    end
    pcall(function()
        writefile(CFG_FOLDER .. "/" .. name .. ".json",
            game:GetService("HttpService"):JSONEncode(snap))
    end)
    return true
end

local function cfgLoad(name)
    local ok, raw = pcall(function()
        return readfile(CFG_FOLDER .. "/" .. name .. ".json")
    end)
    if not ok or not raw then return false end
    local ok2, snap = pcall(function()
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if not ok2 or not snap then return false end

    if not _G.EH_PAID_EXECUTOR then
        for _, flag in ipairs(PAID_ONLY_FLAGS) do snap[flag] = false end
    end

    task.spawn(function()
        local ORDER = {}
        for flag, val in pairs(snap) do
            if type(val) == "boolean" and val == true then
                ORDER[#ORDER+1] = flag
            end
        end

        for flag, val in pairs(snap) do
            if not (type(val) == "boolean" and val == true) then
                Library.Flags[flag] = val

                local tog = Library._toggles and Library._toggles[flag]
                if tog then tog:Set(val) end
            end
        end

        for _, flag in ipairs(ORDER) do
            Library.Flags[flag] = true
            local tog = Library._toggles and Library._toggles[flag]
            if tog then
                task.spawn(function() tog:Set(true) end)
            end
            task.wait(0.04)
        end
    end)
    return true
end

local function cfgDelete(name)
    pcall(function()
        local path = CFG_FOLDER .. "/" .. name .. ".json"
        if isfile(path) then delfile(path) end
    end)
end



local PlrInfoSection = ExpTab:Section("player reports", "Left")

do
    local _nameLabel  = PlrInfoSection:Label("player: " .. player.Name)
    local _rptLabel   = PlrInfoSection:Label("reports: -")
    local _flagsLabel = PlrInfoSection:Label("flags: -")
    local _hsrLabel   = PlrInfoSection:Label("hsr: -")
    local _kdLabel    = PlrInfoSection:Label("k/d: -")
    local _ageLabel   = PlrInfoSection:Label("age: " .. player.AccountAge .. "d")
    local _targetName = player.Name

    local _playerList = {player.Name}
    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr.Name ~= player.Name then _playerList[#_playerList+1] = plr.Name end
    end

    PlrInfoSection:Dropdown({
        Title = "target", Flag = "ReportTarget",
        List = _playerList, Default = _playerList[1],
        Callback = function(v)
            _targetName = v
            _nameLabel:Set("player: " .. v)
        end
    })

    local function _getEntry(name)
        local rl = ReplicatedStorage:FindFirstChild("ReportList")
        if not rl then return nil end
        local en = rl:FindFirstChild(name)
        if en then return en end
        local recent = rl:FindFirstChild("Recent")
        if recent then en = recent:FindFirstChild(name); if en then return en end end
        local mw = rl:FindFirstChild("MostWanted")
        if mw then en = mw:FindFirstChild(name); if en then return en end end
        return nil
    end

    -- Read HSR directly from RS.Players combat stats (same formula as ReportInteractionManager)
    local function _getHSR(targetName)
        local ok, result = pcall(function()
            local p = ReplicatedStorage.Players:FindFirstChild(targetName)
            if not p then return nil end
            local combat = p.Status.GameplayVariables.Combat
            local headshots = combat:GetAttribute("Headshots") or 0
            local bodyshots = combat:GetAttribute("Bodyshots") or 0
            local total = headshots + bodyshots
            if total == 0 then return 0 end
            local hsr = headshots / total
            return math.ceil(hsr * 100)
        end)
        return ok and result or nil
    end

    local function _updateStats()
        pcall(function()
            local name = _targetName
            _nameLabel:Set("player: " .. name)
            local en = _getEntry(name)
            if en then
                local flags = en:GetAttribute("TotalFlags") or en:GetAttribute("Flags") or 0
                local hsr   = en:GetAttribute("HSR") or 0
                if hsr > 0 and hsr <= 1 then hsr = math.floor(hsr * 100 + 0.5) end
                -- if HSR still 0, try ReportGui
                if hsr == 0 then
                    local guiHsr = _getHSR(name)
                    if guiHsr then hsr = guiHsr end
                end
                _flagsLabel:Set("flags: " .. flags)
                _hsrLabel:Set("hsr: " .. hsr .. "%")
            else
                -- no ReportList entry, try ReportGui directly
                local guiHsr = _getHSR(name)
                _flagsLabel:Set("flags: not in ReportList")
                _hsrLabel:Set("hsr: " .. (guiHsr and (guiHsr .. "%") or "not in ReportList"))
            end
            local ps = ReplicatedStorage:FindFirstChild("Players")
            local pStats = ps and ps:FindFirstChild(name)
            if pStats then
                local uac = pStats:FindFirstChild("Status") and pStats.Status:FindFirstChild("UAC")
                local rptFolder = uac and uac:FindFirstChild("Reports")
                local _rptTypes = {[0]="Other",[1]="Aimbot/ESP",[2]="Speedhack/TP",[3]="Noclip/UG",[4]="Flying"}
                local rptCount = 0
                local rptLines = {}
                if rptFolder then
                    for attr, val in pairs(rptFolder:GetAttributes()) do
                        rptCount += 1
                        local typeNum = tonumber(tostring(val)) or 0
                        rptLines[#rptLines+1] = _rptTypes[typeNum] or ("type "..tostring(typeNum))
                    end
                end
                _rptLabel:Set("reports: " .. rptCount .. (#rptLines>0 and " ("..table.concat(rptLines,", ")..")" or ""))
                local ws = pStats:FindFirstChild("Status")
                       and pStats.Status:FindFirstChild("Journey")
                       and pStats.Status.Journey:FindFirstChild("WipeStatistics")
                if ws then
                    local k = ws:GetAttribute("Kills") or 0
                    local d = math.max(ws:GetAttribute("Deaths") or 1, 1)
                    _kdLabel:Set("k/d: "..k.."/"..d.." ("..string.format("%.2f",k/d)..")")
                else _kdLabel:Set("k/d: -") end
            else
                _rptLabel:Set("reports: -")
                _kdLabel:Set("k/d: -")
            end
            local plrObj = game:GetService("Players"):FindFirstChild(name)
            _ageLabel:Set("age: " .. (plrObj and plrObj.AccountAge.."d" or "-"))
        end)
    end

    PlrInfoSection:Button({Title = "refresh stats", Callback = function()
        task.spawn(_updateStats)
    end})

    task.spawn(function() task.wait(3); _updateStats() end)
end

