-- ── State ─────────────────────────────────────────────────────────────────────
local _saActive      = false
local _saMode        = "normal"
local _saFOV         = 150
local _saPrediction  = false
local _saLockTarget  = nil
local _saHooked      = false
local _saNCHooked    = false
local _saOrigCB      = nil
local _saOldNC       = nil

-- ── Target finder ─────────────────────────────────────────────────────────────
local function _saFindTarget()
    local bestPart, bestDist = nil, math.huge
    local cx = cam.ViewportSize.X / 2
    local cy = cam.ViewportSize.Y / 2

    local function check(char)
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local sp, vis, z = cam:WorldToViewportPoint(part.Position)
        if not vis or z <= 0 then return end
        local d = math.sqrt((sp.X - cx)^2 + (sp.Y - cy)^2)
        if d < _saFOV and d < bestDist then bestDist = d; bestPart = part end
    end

    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p ~= player then check(p.Character) end
    end
    local az = workspace:FindFirstChild("AiZones")
    if az then
        for _, zone in ipairs(az:GetChildren()) do
            for _, npc in ipairs(zone:GetChildren()) do
                if npc:IsA("Model") then check(npc) end
            end
        end
    end
    return bestPart
end

-- ── Normal silent aim hook ────────────────────────────────────────────────────
--
--  Signature: CreateBullet(_, p49, p50, p_u_51, p52, _, p53, _, p54)
--    arg5 = p52 = AimPartCanted — a real BasePart
--    bullet direction on server = p52.CFrame.LookVector
--
--  WHY reference scripts get detected:
--    Both brzz_hook and Jiggy pass { CFrame = CFrame.new(...) } — a plain Lua
--    table — as arg5. The server code tries to read .CFrame as a BasePart
--    property and runs numeric comparisons on LookVector components. A fake
--    table returns nil for those, causing "nil <= number" errors that the AC
--    treats as a tamper signal.
--
--  THE FIX:
--    Mutate p52.CFrame directly on the real BasePart, pass the same object,
--    then restore with task.defer after the call unwinds. The server sees a
--    valid BasePart with a redirected LookVector the whole time.
--
local function _hookNormal()
    if _saHooked then return end
    if not hookfunction or not newcclosure then
        EH_Notify("[SA] hookfunction not available on this executor", 5)
        return
    end

    -- Small jitter so every execution doesn't hook at the exact same timestamp
    task.wait(math.random(5, 15) / 100)

    local RS = game:GetService("ReplicatedStorage")
    local ok, BM = pcall(require, RS.Modules.FPS.Bullet)
    if not ok or not BM or not BM.CreateBullet then
        EH_Notify("[SA] Bullet module failed to load", 5)
        return
    end
    if typeof(BM.CreateBullet) ~= "function" then
        EH_Notify("[SA] CreateBullet not a function — AC may have patched it", 5)
        return
    end

    local function bulletCallback(a, b, c, d, aim, e, ammo, t, recoil)
        -- Guard: special weapons (grenades, launchers, melee) pass nil for some
        -- args. Pass them through completely untouched so they fire normally.
        if aim == nil or t == nil or recoil == nil then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end

        -- SA is toggled off — normal shot
        if not (_saActive and _saMode == "normal") then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end

        -- p52 must be a real BasePart — if something changed, bail
        if typeof(aim) ~= "Instance" or not aim:IsA("BasePart") then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end

        -- Snapshot the original CFrame before we touch anything
        local origCF
        pcall(function() origCF = aim.CFrame end)
        if not origCF then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end

        -- Find the closest enemy inside our FOV circle
        local target = _saFindTarget()
        if not target then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end
        _saLockTarget = target

        -- Build destination position (with optional ballistic prediction)
        local aimPos  = origCF.Position
        local finalPos = target.Position

        if _saPrediction then
            pcall(function()
                local ammoObj = RS.AmmoTypes:FindFirstChild(ammo)
                if not ammoObj then return end
                local speed = ammoObj:GetAttribute("MuzzleVelocity")
                local drop  = ammoObj:GetAttribute("ProjectileDrop")
                if not speed or not drop then return end
                local hrp = target.Parent and target.Parent:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local vel  = hrp.AssemblyLinearVelocity
                local dist = (target.Position - aimPos).Magnitude
                local tof  = dist / speed
                finalPos = Vector3.new(
                    target.Position.X + vel.X * tof,
                    target.Position.Y,             -- keep vertical as-is (drop handled server-side)
                    target.Position.Z + vel.Z * tof
                )
            end)
        end

        -- ── THE KEY FIX ──────────────────────────────────────────────────────
        -- Set the CFrame directly on the real BasePart (AimPartCanted).
        -- Do NOT replace aim with { CFrame = ... } — that's a Lua table, and
        -- the server reads .CFrame.LookVector as a BasePart property with
        -- numeric comparisons. A fake table causes nil arithmetic → AC flag.
        local redirected = false
        pcall(function()
            aim.CFrame = CFrame.new(aimPos, finalPos)
            redirected = true
        end)

        if not redirected then
            -- CFrame write failed (e.g., part locked by engine mid-frame)
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end

        -- Call the real CreateBullet with the exact same BasePart object.
        -- The server receives a valid BasePart the whole time — indistinguishable
        -- from a normal shot. Only the LookVector is different.
        local r1, r2, r3, r4 = _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)

        -- Restore the original CFrame after the call fully unwinds.
        -- task.defer fires on the next Heartbeat step, after all synchronous
        -- game code in this frame (including the bullet module internals) is done.
        task.defer(function()
            pcall(function()
                if aim and aim.Parent then
                    aim.CFrame = origCF
                end
            end)
        end)

        return r1, r2, r3, r4
    end

    local hookOk, hookErr = pcall(function()
        _saOrigCB = hookfunction(BM.CreateBullet, newcclosure(bulletCallback))
    end)

    if not hookOk or not _saOrigCB then
        EH_Notify("[SA] hook failed: " .. tostring(hookErr), 5)
        return
    end

    _saHooked = true
    EH_Notify("[SA] silent aim active", 3)
end

local function _unhookPerfect()
    if not _saOldNC then return end
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        mt.__namecall = _saOldNC
        setreadonly(mt, true)
    end)
    _saOldNC = nil; _saNCHooked = false
end

