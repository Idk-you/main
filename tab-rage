                        for _, ammo in ipairs(ammos) do
                            if mag.ammoType == ammo.slotType then
                                pcall(function() remote:FireServer(ammo.slot, mag.slot, ammo.parent, mag.parent) end)
                                task.wait(); break
                            end
                        end
                    end
                end)
            end
        end)
    end
end})

-- ─── no sway ──────────────────────────────────────────────────────
do
    local _swayEnabled = false
    local _swayPatched = false
    local function _patchSway()
        if _swayPatched then return end
        pcall(function()
            local rs = ReplicatedStorage
            local success, mod = pcall(require, rs:FindFirstChild("Modules") and rs.Modules:FindFirstChild("FPS"))
            if success and mod and mod.updateClient then
                local old_update = mod.updateClient
                mod.updateClient = function(a1, a2, a3)
                    local r1, r2, r3 = old_update(a1, a2, a3)
                    if _swayEnabled and a1 and a1.springs then
                        for _, spring in pairs(a1.springs) do
                            if spring.Position then spring.Position = Vector3.new() end
                            if spring.Speed then spring.Speed = 0 end
                        end
                    end
                    return r1, r2, r3
                end
                _swayPatched = true
            end
        end)
    end
    WeapSection:Toggle({Title = "no sway", Flag = "WepNoSway", Default = false, Callback = function(s)
        _swayEnabled = s
        if s then task.spawn(_patchSway) end
    end})
end

