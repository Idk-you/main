-- ── IH state — completely independent of SA ───────────────────────────────────
local _ihActive   = false
local _ihHooked   = false
local _ihOldNC    = nil
local _ihTarget   = nil  -- set inside Raycast intercept, read by FireServer intercept

-- ── Ballistic helpers (petal) ─────────────────────────────────────────────────
local function _saaSolve(A, B, C)
    local d = B*B - 4*A*C
    if d < 0 then return end
    local s = math.sqrt(d)
    return (-B - s)/(2*A), (-B + s)/(2*A)
end
local function _saaFlight(dir, grav, speed)
    local r1, r2 = _saaSolve(grav:Dot(grav)/4, grav:Dot(dir) - speed^2, dir:Dot(dir))
    if r1 and r2 then
        local t = math.min(r1, r2)
        if t > 0 then return math.sqrt(t) end
    end
    return 0
end
local function _saaPredict(part, origin, speed, drop)
    local g = Vector3.yAxis * (drop * 2)
    local t = _saaFlight(part.Position - origin, g, speed)
    return part.Position + part.Velocity * t
end
local function _saaDrop(origin, target, speed, drop)
    local g = Vector3.yAxis * (drop * 2)
    local t = _saaFlight(target - origin, g, speed)
    return 0.5 * g * t^2
end

-- ── Target finder ─────────────────────────────────────────────────────────────
local function _saGetTarget()
    local closest, bestDist = nil, _saFOV
    local center = cam.ViewportSize / 2
    local az = workspace:FindFirstChild("AiZones")
    if az then
        for _, zone in ipairs(az:GetChildren()) do
            for _, char in ipairs(zone:GetChildren()) do
                if char:IsA("Model") then
                    local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                    local hum  = char:FindFirstChildOfClass("Humanoid")
                    if part and hum and hum.Health > 0 then
                        local pos, onscreen = cam:WorldToViewportPoint(part.Position)
                        if onscreen then
                            local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                            if d < bestDist then bestDist = d; closest = part end
                        end
                    end
                end
            end
        end
    end
    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr ~= player and plr.Character then
            local hum  = plr.Character:FindFirstChildOfClass("Humanoid")
            local part = plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
            if part and hum and hum.Health > 0 then
                local pos, onscreen = cam:WorldToViewportPoint(part.Position)
                if onscreen then
                    local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if d < bestDist then bestDist = d; closest = part end
                end
            end
        end
    end
    return closest
end

-- ── Silent aim — EXACT same working version, zero changes ─────────────────────
local function _hookNormal()
    if _saHooked then return end
    if not hookfunction then
        EH_Notify("[SA] hookfunction unavailable", 5); return
    end
    local RS = game:GetService("ReplicatedStorage")
    local ok, BulletModule = pcall(require, RS.Modules.FPS.Bullet)
    if not ok or not BulletModule or not BulletModule.CreateBullet then
        EH_Notify("[SA] Bullet module unavailable", 5); return
    end

    local OldBullet
    OldBullet = hookfunction(BulletModule.CreateBullet, function(a, b, c, d, aim, e, ammo, t, recoil)
        if _saActive and not checkcaller() then
            local target = _saGetTarget()
            if target and aim and aim.Position then
                local ammoObj = RS.AmmoTypes:FindFirstChild(ammo)
                if ammoObj then
                    ammoObj:SetAttribute("Drag", 0)
                    local speed = ammoObj:GetAttribute("MuzzleVelocity") or 300
                    local drop  = ammoObj:GetAttribute("ProjectileDrop") or 0
                    local pos   = _saPrediction
                        and _saaPredict(target, aim.Position, speed, drop)
                        or  target.Position
                    local vdrop = _saaDrop(aim.Position, pos, speed, drop)
                    return OldBullet(a, b, c, d,
                        { CFrame = CFrame.new(aim.Position, pos + vdrop) },
                        e, ammo, t, recoil)
                end
            end
        end
        return OldBullet(a, b, c, d, aim, e, ammo, t, recoil)
    end)

    _saOrigCB = OldBullet
    _saHooked = true
    EH_Notify("[SA] silent aim active", 3)
end

-- ── Instant hit — hookmetamethod only, SA hookfunction untouched ───────────────
--
--  How it works:
--
--  The bullet sim's RenderStepped loop (FPS.Bullet onStep) runs every frame:
--    1. workspace:Raycast(origin, Unit*stepSize, params)  ← we intercept this
--       We return a fake result pointing at the closest FOV target.
--       _ihTarget is set here (not in SA hook — that's the previous bug's fix).
--
--    2. When the Raycast hits a Humanoid ancestor, game calls:
--       ProjectileInflict:FireServer(hitPart, offsetCF, bulletId, tickTimestamp)
--       args[4] = tickTimestamp — server validates this against expected travel time.
--       We add dist/speed to it so the server sees a believable travel duration.
--       We also delay this call by 2×ping so FireProjectile:InvokeServer (which
--       runs in a coroutine just before the sim loop) has time to register the
--       bullet with the server first. Without this delay you get blood but no damage.
--
--  Part 3: GetAttribute("ProjectileDrop") and ("Drag") → 0
--       Makes trajectory straight so the fake hit position is geometrically consistent.
--
local function _hookInstantHit()
    if _ihHooked then return end
    if not hookmetamethod then
        EH_Notify("[IH] hookmetamethod unavailable", 5); return
    end

    local RS = game:GetService("ReplicatedStorage")
    local LP = game:GetService("Players").LocalPlayer

    local function _getSpeed()
        local speed = 300
        pcall(function()
            local holding  = player.Character and player.Character:FindFirstChild("Holding")
            local wep      = holding and holding.Value
            local ammoType = wep and wep:GetAttribute("AmmoType")
            if ammoType then
                local ammoObj = RS.AmmoTypes:FindFirstChild(ammoType)
                if ammoObj then speed = ammoObj:GetAttribute("MuzzleVelocity") or speed end
            end
        end)
        return speed
    end

    local oldNC
    oldNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        if checkcaller() then return oldNC(self, ...) end

        local method = getnamecallmethod()
        local args   = { ... }

        -- Part 3: zero drop and drag on AmmoType objects only
        if method == "GetAttribute" and _ihActive then
            local attr = args[1]
            if attr == "ProjectileDrop" or attr == "Drag" then
                local isAmmo = false
                pcall(function()
                    isAmmo = self.Parent and self.Parent.Name == "AmmoTypes"
                end)
                if isAmmo then return 0 end
            end
        end

        -- Part 1: intercept workspace:Raycast from the bullet sim
        -- Return a fake RaycastResult pointing at the closest FOV target.
        -- _ihTarget is set here so SA hookfunction stays completely untouched.
        if method == "Raycast" and self == workspace and _ihActive then
            local target = _saGetTarget()
            if target then
                _ihTarget = target
                local origin = args[1]
                local normal = Vector3.new(0, 1, 0)
                pcall(function()
                    if typeof(origin) == "Vector3" then
                        normal = (origin - target.Position).Unit
                    end
                end)
                return {
                    Instance = target,
                    Position = target.Position,
                    Normal   = normal,
                    Material = Enum.Material.SmoothPlastic,
                }
            end
        end

        -- Part 2: ProjectileInflict:FireServer — delay + tick correction
        -- args[4] = tickTimestamp from the bullet sim (this is the value the
        -- server checks against expected travel time). We add dist/speed.
        -- We delay by 2×ping so the bullet is registered server-side first.
        if method == "FireServer" and self.Name == "ProjectileInflict" and _ihActive then
            local target    = _ihTarget
            local savedSelf = self
            local savedArgs = { unpack(args) }
            _ihTarget = nil  -- clear for next shot

            pcall(function()
                if target and type(savedArgs[4]) == "number" then
                    local dist  = (target.Position - cam.CFrame.Position).Magnitude
                    local speed = _getSpeed()
                    if speed > 0 then
                        savedArgs[4] = savedArgs[4] + dist / speed
                    end
                end
            end)

            local pingDelay = 0.1
            pcall(function()
                pingDelay = math.max(0.1, LP:GetNetworkPing() * 2)
            end)

            task.delay(pingDelay, function()
                pcall(function()
                    oldNC(savedSelf, unpack(savedArgs))
                end)
            end)

            -- suppress original, our delayed version handles it
            return
        end

        return oldNC(self, ...)
    end))

    _ihOldNC  = oldNC
    _ihHooked = true
    EH_Notify("[IH] instant hit active", 3)
end

local function _unhookInstantHit()
    if not _ihOldNC then return end
    pcall(function()
        hookmetamethod(game, "__namecall", _ihOldNC)
    end)
    _ihOldNC  = nil
    _ihHooked = false
    _ihTarget = nil
    EH_Notify("[IH] instant hit off", 2)
end

