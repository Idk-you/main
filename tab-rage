-- ── State ─────────────────────────────────────────────────────────────────────
local _saActive      = false
local _saMode        = "normal"   -- "normal" | "perfect"
local _saFOV         = 150
local _saPrediction  = false
local _saLockTarget  = nil
local _saHooked      = false      -- normal hook applied
local _saNCHooked    = false      -- perfect namecall hook applied
local _saOrigCB      = nil
local _saOldNC       = nil
local _saInflictRem  = nil

-- ── Ammo helpers ──────────────────────────────────────────────────────────────
local function _getAmmoType()
    local t = nil
    pcall(function()
        local holding = player.Character:FindFirstChild("Holding")
        t = holding and holding.Value and holding.Value:GetAttribute("AmmoType")
    end)
    return t
end

local function _getMuzzleVelocity()
    local mv = 300
    pcall(function()
        local name = _getAmmoType()
        if not name then return end
        local af = game:GetService("ReplicatedStorage").AmmoTypes:FindFirstChild(name)
        if af then mv = af:GetAttribute("MuzzleVelocity") or mv end
    end)
    return mv
end

-- ── Target finder ─────────────────────────────────────────────────────────────
local function _saFindTarget()
    local bestPart, bestDist = nil, math.huge
    local cx = cam.ViewportSize.X / 2
    local cy = cam.ViewportSize.Y / 2

    local function check(char)
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local sp, vis, z = cam:WorldToViewportPoint(part.Position)
        if not vis or z <= 0 then return end
        local d = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
        if d < _saFOV and d < bestDist then bestDist = d; bestPart = part end
    end

    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p ~= player then check(p.Character) end
    end
    local az = workspace:FindFirstChild("AiZones")
    if az then
        for _, zone in ipairs(az:GetChildren()) do
            for _, npc in ipairs(zone:GetChildren()) do
                if npc:IsA("Model") then check(npc) end
            end
        end
    end
    return bestPart
end

-- ── Prediction ────────────────────────────────────────────────────────────────
local function _saPredict(part)
    if not _saPrediction then return part.Position end
    local hrp = part.Parent and part.Parent:FindFirstChild("HumanoidRootPart")
    if not hrp then return part.Position end
    local vel  = hrp.AssemblyLinearVelocity
    local dist = (part.Position - cam.CFrame.Position).Magnitude
    local mv   = _getMuzzleVelocity()
    local tof  = dist / mv
    return Vector3.new(
        part.Position.X + vel.X * tof,
        part.Position.Y,
        part.Position.Z + vel.Z * tof
    )
end

-- ── Normal silent aim ─────────────────────────────────────────────────────────
-- Hooks RS.Modules.FPS.Bullet → CreateBullet(a, b, c, d, aim, e, ammo, tick, recoil)
-- arg5 (aim) = table with .CFrame → we replace aim.CFrame to face target
local function _hookNormal()
    if _saHooked then return end
    if not hookfunction or not newcclosure then
        EH_Notify("[SA] hookfunction not supported on this executor", 5); return
    end
    task.wait(math.random(5, 15) / 100)
    local ok, BM = pcall(require, game:GetService("ReplicatedStorage").Modules.FPS.Bullet)
    if not ok or not BM or not BM.CreateBullet then
        EH_Notify("[SA] Bullet module failed to load", 5); return
    end
    if typeof(BM.CreateBullet) ~= "function" then
        EH_Notify("[SA] CreateBullet not a function - may be AC patched", 5); return
    end

    -- p52 (aim) is a BasePart. Its .CFrame.LookVector = bullet direction.
    -- We temporarily set p52.CFrame to face the target, call original, then restore.
    local function bulletCallback(a, b, c, d, aim, e, ammo, t, recoil)
        -- Guard: nil args = special weapon, pass through untouched
        if t == nil or recoil == nil or aim == nil then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end
        if not (_saActive and _saMode == "normal") then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end
        -- aim is a BasePart (AimPartCanted) - get its current CFrame
        local origCF = nil
        pcall(function() origCF = aim.CFrame end)
        if not origCF then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end
        local aimPos = origCF.Position
        -- Find target
        local target = _saFindTarget()
        if not target then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end
        _saLockTarget = target
        -- Compute final position with optional prediction
        local finalPos = target.Position
        pcall(function()
            if not _saPrediction then return end
            local ammoObj = game:GetService("ReplicatedStorage").AmmoTypes:FindFirstChild(ammo)
            if not ammoObj then return end
            local speed = ammoObj:GetAttribute("MuzzleVelocity")
            local drop  = ammoObj:GetAttribute("ProjectileDrop")
            if not speed or not drop then return end
            local hrp = target.Parent and target.Parent:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local vel = hrp.AssemblyLinearVelocity
            local dist = (target.Position - aimPos).Magnitude
            local tof  = dist / speed
            finalPos = Vector3.new(
                target.Position.X + vel.X * tof,
                target.Position.Y,
                target.Position.Z + vel.Z * tof
            )
        end)
        -- Set aim BasePart CFrame to face target (this changes LookVector)
        local setOk = pcall(function()
            aim.CFrame = CFrame.new(aimPos, finalPos)
        end)
        if not setOk then
            return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
        end
        -- Call original with same args (aim BasePart now faces target)
        local results = table.pack(pcall(_saOrigCB, a, b, c, d, aim, e, ammo, t, recoil))
        -- Restore original CFrame immediately after
        task.defer(function()
            pcall(function() aim.CFrame = origCF end)
        end)
        if results[1] then
            return table.unpack(results, 2, results.n)
        end
        -- If pcall failed, try calling without redirect as fallback
        return _saOrigCB(a, b, c, d, aim, e, ammo, t, recoil)
    end

    local hookOk, hookErr = pcall(function()
        _saOrigCB = hookfunction(BM.CreateBullet, newcclosure(bulletCallback))
    end)
    if not hookOk or not _saOrigCB then
        EH_Notify("[SA] hook failed: " .. tostring(hookErr), 5); return
    end
    _saHooked = true
    EH_Notify("[SA] silent aim hooked!", 3)
end

end

local function _unhookPerfect()
    if not _saOldNC then return end
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        mt.__namecall = _saOldNC
        setreadonly(mt, true)
    end)
    _saOldNC = nil; _saNCHooked = false
end

