    local function _fmCache()
        table.clear(_fmModules); table.clear(_fmOriginals); _fmCached = false
        local items = ReplicatedStorage:FindFirstChild("ItemsList")
        if not items then return end
        for _, v in ipairs(items:GetDescendants()) do
