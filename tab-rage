                    if y == "ammo" and ip:GetAttribute("ItemType") == "Ammo" then
                        return ip:GetAttribute("SlotType")
                    end
                end
                return nil
            end
            local function _gmax(x)
                local il = rs:FindFirstChild("ItemsList")
                if il and il:FindFirstChild(x.Name) then
                    local ip = il[x.Name]:FindFirstChild("ItemProperties")
                    if ip then return ip:GetAttribute("MaxLoadedAmmo") or 0 end
                end
