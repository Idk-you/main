-- ── SA state ──────────────────────────────────────────────────────────────────
local _saActive     = false
local _saMode       = "normal"
local _saFOV        = 150
local _saPrediction = false
local _saTargetPart = nil   -- current locked BasePart (Head / HRP)
local _saHooked     = false -- CreateBullet hook installed
local _saNCHooked   = false -- hookmetamethod installed
local _saOrigCB     = nil   -- original CreateBullet (hookfunction return)
local _saOldNC      = nil   -- original __namecall  (hookmetamethod return)

-- ── Target finder — mirrors Jiggy's get_target() ─────────────────────────────
local function _saFindTarget()
    local bestPart, bestDist = nil, math.huge
    local cx = cam.ViewportSize.X / 2
    local cy = cam.ViewportSize.Y / 2

    local function check(char)
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local sp, vis, z = cam:WorldToViewportPoint(part.Position)
        if not vis or z <= 0 then return end
        local d = math.sqrt((sp.X - cx)^2 + (sp.Y - cy)^2)
        if d < _saFOV and d < bestDist then bestDist = d; bestPart = part end
    end

    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p ~= player then check(p.Character) end
    end
    local az = workspace:FindFirstChild("AiZones")
    if az then
        for _, zone in ipairs(az:GetChildren()) do
            for _, npc in ipairs(zone:GetChildren()) do
                if npc:IsA("Model") then check(npc) end
            end
        end
    end
    return bestPart
end

-- ── _hookNormal ───────────────────────────────────────────────────────────────
--
--  Ported directly from Jiggy's working implementation.
--
--  Two hooks:
--
--  1. hookmetamethod(__namecall) — intercepts workspace:Raycast calls that come
--     from FPS.Bullet's RenderStepped simulation loop and redirects the ray
--     direction toward _saTargetPart. This is Jiggy's "instant_hit" Raycast
--     block. Uses hookmetamethod (NOT getrawmetatable+setreadonly — that approach
--     silently fails on most executors and breaks ALL method calls, which is why
--     previous versions caused the gun to stop firing entirely).
--
--  2. hookfunction(CreateBullet) — replaces args[5] (p52 / AimPartCanted) with
--     a Lua table { CFrame = CFrame.new(camPos, targetPos) } so the initial
--     bullet direction on the server points at the target. This is Jiggy's
--     "manipulation" block. The nil <= number errors are expected — they are
--     generated by game code that tries to call BasePart methods on the fake
--     table, but they are caught by the game's own pcall wrappers and do NOT
--     prevent the bullet from firing.
--
local function _hookNormal()
    if _saHooked and _saNCHooked then return end

    if not hookfunction or not newcclosure then
        EH_Notify("[SA] hookfunction unavailable on this executor", 5)
        return
    end

    -- ── 1. hookmetamethod — Raycast redirect (Jiggy's "instant_hit" block) ───
    -- Must be installed FIRST so it's active when the CreateBullet simulation
    -- starts calling workspace:Raycast.
    if not _saNCHooked then
        if not hookmetamethod then
            EH_Notify("[SA] hookmetamethod unavailable — Raycast redirect disabled", 3)
        else
            local function ncCallback(self, ...)
                -- Always let our own executor calls through untouched
                if checkcaller() then
                    return _saOldNC(self, ...)
                end

                local method = getnamecallmethod()
                local args   = { ... }

                -- Raycast redirect — mirrors Jiggy's instant_hit Raycast block exactly.
                -- getinfo(3) is the caller of the method; for the bullet sim loop it
                -- is always inside FPS.Bullet.
                if method == "Raycast"
                    and _saActive
                    and _saMode == "normal"
                    and _saTargetPart
                then
                    local fromBullet = false
                    pcall(function()
                        local info = debug.getinfo(3, "S")
                        if info and info.short_src then
                            local src = info.short_src
                            -- Match the full path Jiggy checks:
                            -- "ReplicatedStorage.Modules.FPS.Bullet"
                            if src:find("FPS") or src:find("Bullet") then
                                fromBullet = true
                            end
                        end
                    end)
                    if fromBullet then
                        -- Jiggy: args[2] = (target.Position - args[1]).Unit * 9e16
                        args[2] = (_saTargetPart.Position - args[1]).Unit * 9e16
                        return _saOldNC(self, unpack(args))
                    end
                end

                return _saOldNC(self, ...)
            end

            -- hookmetamethod returns the original __namecall — safe on all executors
            _saOldNC    = hookmetamethod(game, "__namecall", newcclosure(ncCallback))
            _saNCHooked = true
        end
    end

    -- ── 2. hookfunction — CreateBullet args[5] redirect (Jiggy's main block) ─
    if not _saHooked then
        task.wait(math.random(5, 15) / 100)

        local RS = game:GetService("ReplicatedStorage")
        local ok, BM = pcall(require, RS.Modules.FPS.Bullet)
        if not ok or not BM or not BM.CreateBullet then
            EH_Notify("[SA] Bullet module unavailable", 5); return
        end
        if typeof(BM.CreateBullet) ~= "function" then
            EH_Notify("[SA] CreateBullet not a function", 5); return
        end

        -- Declare hook variable upfront so the callback can reference it.
        -- Mirrors Jiggy's pattern: local silent_aim_hook; silent_aim_hook = hookfunction(...)
        local saHook
        local function bulletCallback(...)
            local args = { ... }

            -- Signature: CreateBullet(_, p49, p50, p_u_51, p52, _, p53, _, p54)
            -- args[5] = p52 = AimPartCanted (the aim BasePart)
            -- args[7] = p53 = ammo name string
            -- args[9] = p54 = recoil shot count
            --
            -- Guard: special weapons (grenades, launchers, melee) pass nil for
            -- some args. Let them through completely unchanged.
            if args[5] == nil or args[7] == nil or args[9] == nil then
                return saHook(unpack(args))
            end

            if _saActive and _saMode == "normal" then
                local target = _saFindTarget()
                if target then
                    _saTargetPart = target

                    -- Build final aim position with optional velocity prediction
                    local targetPos = target.Position
                    if _saPrediction then
                        pcall(function()
                            local ammoObj = RS.AmmoTypes:FindFirstChild(args[7])
                            if not ammoObj then return end
                            local speed = ammoObj:GetAttribute("MuzzleVelocity")
                            if not speed or speed <= 0 then return end
                            local hrp = target.Parent
                                    and target.Parent:FindFirstChild("HumanoidRootPart")
                            if not hrp then return end
                            local vel  = hrp.AssemblyLinearVelocity
                            local dist = (target.Position - cam.CFrame.Position).Magnitude
                            local tof  = dist / speed
                            targetPos  = Vector3.new(
                                target.Position.X + vel.X * tof,
                                target.Position.Y,
                                target.Position.Z + vel.Z * tof
                            )
                        end)
                    end

                    -- Replace args[5] (AimPartCanted / p52) with a CFrame-compatible
                    -- table pointing from camera position toward target.
                    -- Jiggy: args[5] = { CFrame = CFrame.new(CurrentCamera.CFrame.Position, target.Position) }
                    -- The game reads p52.CFrame.LookVector for bullet direction.
                    -- nil <= number errors from other p52 property accesses are caught
                    -- by the game's own pcall and do not block the shot.
                    args[5] = { CFrame = CFrame.new(cam.CFrame.Position, targetPos) }
                else
                    _saTargetPart = nil
                end
            else
                _saTargetPart = nil
            end

            -- Call original via saHook (hookfunction return value = original).
            -- Jiggy: return silent_aim_hook(unpack(args))
            return saHook(unpack(args))
        end

        local hookOk, hookErr = pcall(function()
            saHook = hookfunction(BM.CreateBullet, newcclosure(bulletCallback))
        end)
        if not hookOk or not saHook then
            EH_Notify("[SA] hook failed: " .. tostring(hookErr), 5); return
        end

        _saOrigCB = saHook
        _saHooked = true
    end

    EH_Notify("[SA] silent aim active", 3)
end

-- ── Unhook (used when switching modes or disabling) ───────────────────────────
local function _unhookNormal()
    -- Unhook namecall
    if _saOldNC and hookmetamethod then
        pcall(function()
            hookmetamethod(game, "__namecall", _saOldNC)
        end)
        _saOldNC    = nil
        _saNCHooked = false
    end
    -- Note: hookfunction cannot be undone cleanly at runtime without the original
    -- reference. _saHooked stays true across sessions to prevent double-hooking.
    _saTargetPart = nil
end

local function _unhookPerfect()
    -- placeholder — _hookPerfect defined elsewhere in the codebase
    _saTargetPart = nil
end

