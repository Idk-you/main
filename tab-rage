WeapSection:Toggle({Title = "legit no recoil", Flag = "WepLegitRecoil", Default = false, Callback = function(s)
    ModS.noRecoil = s
    local weaponsFolder = ReplicatedStorage:FindFirstChild("RangedWeapons")
    if not weaponsFolder then return end
    if s then
        -- Save originals and zero out RecoilPattern x/y values
        if not ModS._legitOrigRecoil then ModS._legitOrigRecoil = {} end
        for _, weapon in ipairs(weaponsFolder:GetChildren()) do
            local recoilFolder = weapon:FindFirstChild("RecoilPattern")
            if recoilFolder then
                if not ModS._legitOrigRecoil[weapon.Name] then
                    ModS._legitOrigRecoil[weapon.Name] = {}
                end
                for _, step in ipairs(recoilFolder:GetChildren()) do
                    local x = step:FindFirstChild("x")
                    local y = step:FindFirstChild("y")
                    if x or y then
                        ModS._legitOrigRecoil[weapon.Name][step.Name] =
                            ModS._legitOrigRecoil[weapon.Name][step.Name] or {}
                    end
                    if x and x:IsA("NumberValue") then
                        ModS._legitOrigRecoil[weapon.Name][step.Name].x = x.Value
                        x.Value = 0
                    end
                    if y and y:IsA("NumberValue") then
                        ModS._legitOrigRecoil[weapon.Name][step.Name].y = y.Value
                        y.Value = 0
                    end
                end
            end
        end
    else
        -- Restore original recoil values
        if ModS._legitOrigRecoil then
            for weaponName, steps in pairs(ModS._legitOrigRecoil) do
                local weapon = weaponsFolder:FindFirstChild(weaponName)
                if weapon then
                    local recoilFolder = weapon:FindFirstChild("RecoilPattern")
                    if recoilFolder then
                        for _, step in ipairs(recoilFolder:GetChildren()) do
                            local saved = steps[step.Name]
                            if saved then
                                local x = step:FindFirstChild("x")
                                local y = step:FindFirstChild("y")
                                if x and saved.x ~= nil then x.Value = saved.x end
                                if y and saved.y ~= nil then y.Value = saved.y end
                            end
                        end
                    end
                end
            end
            ModS._legitOrigRecoil = {}
        end
    end
end})
