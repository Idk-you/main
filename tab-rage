WeapSection:Toggle({Title = "instant mag refill", Flag = "InstantMag", Callback = function(s)
    BrzS.instantMagRefill = s
    if s then
        task.spawn(function()
            local rs = ReplicatedStorage
            local function _gat(x, y)
                local il = rs:FindFirstChild("ItemsList")
                if il and il:FindFirstChild(x.Name) then
                    local ip = il[x.Name]:FindFirstChild("ItemProperties")
                    if not ip then return nil end
                    if y == "mag"  then return ip:GetAttribute("AmmoType") end
                    if y == "ammo" and ip:GetAttribute("ItemType") == "Ammo" then
                        return ip:GetAttribute("SlotType")
                    end
                end
                return nil
            end
            local function _gmax(x)
                local il = rs:FindFirstChild("ItemsList")
                if il and il:FindFirstChild(x.Name) then
                    local ip = il[x.Name]:FindFirstChild("ItemProperties")
                    if ip then return ip:GetAttribute("MaxLoadedAmmo") or 0 end
                end
                return 0
            end
            local remote = rs:FindFirstChild("Remotes") and rs.Remotes:FindFirstChild("InventoryMove")
            while BrzS.instantMagRefill do
                task.wait(0.5)
                pcall(function()
                    local inv = rs.Players and rs.Players:FindFirstChild(player.Name)
                             and rs.Players[player.Name]:FindFirstChild("Inventory")
                    if not inv or not remote then return end
                    local mags, ammos = {}, {}
                    for _, v in ipairs(inv:GetChildren()) do
                        local slot = v:GetAttribute("Slot")
                        if slot and slot:lower():find("clothing") then
                            local ci = v:FindFirstChild("Inventory")
                            if ci then
                                for _, x in ipairs(ci:GetChildren()) do
                                    local loaded = x:GetAttribute("LoadedAmmo")
                                    if loaded ~= nil then
                                        local mt = _gat(x, "mag")
                                        if mt and loaded < _gmax(x) then
                                            table.insert(mags, {item=x, ammoType=mt, slot=x:GetAttribute("Slot"), parent=ci})
                                        end
                                    else
                                        local at = _gat(x, "ammo")
                                        if at then table.insert(ammos, {item=x, slotType=at, slot=x:GetAttribute("Slot"), parent=ci}) end
                                    end
                                end
                            end
                        end
                    end
                    for _, mag in ipairs(mags) do
                        for _, ammo in ipairs(ammos) do
                            if mag.ammoType == ammo.slotType then
                                pcall(function() remote:FireServer(ammo.slot, mag.slot, ammo.parent, mag.parent) end)
                                task.wait(); break
                            end
                        end
                    end
                end)
            end
        end)
    end
end})

-- ─── no sway ──────────────────────────────────────────────────────
do
    local _swayEnabled = false
    local _swayPatched = false

    local function _patchSway()
        if _swayPatched then return end
        pcall(function()
            local rs = ReplicatedStorage
            local success, mod = pcall(require, rs:FindFirstChild("Modules") and rs.Modules:FindFirstChild("FPS"))
            if success and mod and mod.updateClient then
                local old_update = mod.updateClient
                mod.updateClient = function(a1, a2, a3)
                    local r1, r2, r3 = old_update(a1, a2, a3)
                    if _swayEnabled and a1 and a1.springs then
                        for _, spring in pairs(a1.springs) do
                            if spring.Position then spring.Position = Vector3.new() end
                            if spring.Speed then spring.Speed = 0 end
                        end
                    end
                    return r1, r2, r3
                end
                _swayPatched = true
            end
        end)
    end

    WeapSection:Toggle({Title = "no sway", Flag = "WepNoSway", Default = false, Callback = function(s)
        _swayEnabled = s
        if s then task.spawn(_patchSway) end
    end})
end

-- ─── unlock firemodes ─────────────────────────────────────────────
do
    local _fmEnabled = false
    local _fmModules = {}
    local _fmOriginals = {}
    local _fmCached = false

    local function _fmCache()
        table.clear(_fmModules); table.clear(_fmOriginals); _fmCached = false
        local items = ReplicatedStorage:FindFirstChild("ItemsList")
        if not items then return end
        for _, v in ipairs(items:GetDescendants()) do
            if v:IsA("ModuleScript") and v.Name == "SettingsModule" then
                local ok, mod = pcall(require, v)
                if ok and type(mod) == "table" then
                    _fmModules[#_fmModules+1] = mod
                    if type(mod.FireModes) == "table" then
                        local copy = {}
                        for i, m in ipairs(mod.FireModes) do copy[i] = m end
                        _fmOriginals[mod] = copy
                    end
                end
            end
        end
        _fmCached = true
    end

    WeapSection:Toggle({Title = "unlock firemodes", Flag = "WepUnlockFiremodes", Default = false, Callback = function(s)
        _fmEnabled = s
        if s then
            if not _fmCached then task.spawn(_fmCache) end
            task.spawn(function()
                if not _fmCached then task.wait(1) end
                for _, mod in ipairs(_fmModules) do
                    pcall(function() mod.FireModes = {"Auto","Semi"} end)
                end
            end)
        else
            for mod, modes in pairs(_fmOriginals) do
                pcall(function() mod.FireModes = modes end)
            end
        end
    end})
end

-- ─── rpm booster ──────────────────────────────────────────────────
do
    local _rpmEnabled = false
    local _rpmInterval = 0.05
    local _rpmModules = {}
    local _rpmOrig = {}

    local function _rpmCache()
        table.clear(_rpmModules); table.clear(_rpmOrig)
        local items = ReplicatedStorage:FindFirstChild("ItemsList")
        if not items then return end
        for _, v in ipairs(items:GetDescendants()) do
            if v:IsA("ModuleScript") and v.Name == "SettingsModule" then
                local ok, mod = pcall(require, v)
                if ok and type(mod) == "table" and type(mod.FireRate) == "number" then
                    _rpmModules[#_rpmModules+1] = mod
                    _rpmOrig[mod] = mod.FireRate
                end
            end
        end
    end

    local function _rpmApply()
        for _, mod in ipairs(_rpmModules) do
            pcall(function() mod.FireRate = _rpmInterval end)
        end
    end

    local function _rpmRestore()
        for mod, rate in pairs(_rpmOrig) do
            pcall(function() mod.FireRate = rate end)
        end
    end

    WeapSection:Toggle({Title = "rpm booster", Flag = "WepRPMBoost", Default = false, Callback = function(s)
        _rpmEnabled = s
        if s then task.spawn(function() _rpmCache(); _rpmApply() end)
        else _rpmRestore() end
    end})
    WeapSection:Slider({Title = "firerate (lower = faster)", Flag = "WepRPMVal", Symbol = "", Default = 5, Min = 0, Max = 10, Decimals = 2, Callback = function(v)
        _rpmInterval = v / 100
        if _rpmEnabled then _rpmApply() end
    end})
end



local SASection = RageTab:Section("silent aim", "Right")

-- ── State ─────────────────────────────────────────────────────────────────────
local _saActive      = false
local _saMode        = "normal"   -- "normal" | "perfect"
local _saFOV         = 150
local _saPrediction  = false
local _saLockTarget  = nil
local _saHooked      = false      -- normal hook applied
local _saNCHooked    = false      -- perfect namecall hook applied
local _saOrigCB      = nil
local _saOldNC       = nil
local _saInflictRem  = nil

-- ── Ammo helpers ──────────────────────────────────────────────────────────────
local function _getAmmoType()
    local t = nil
    pcall(function()
        local holding = player.Character:FindFirstChild("Holding")
        t = holding and holding.Value and holding.Value:GetAttribute("AmmoType")
    end)
    return t
end

local function _getMuzzleVelocity()
    local mv = 300
    pcall(function()
        local name = _getAmmoType()
        if not name then return end
        local af = game:GetService("ReplicatedStorage").AmmoTypes:FindFirstChild(name)
        if af then mv = af:GetAttribute("MuzzleVelocity") or mv end
    end)
    return mv
end

-- ── Target finder ─────────────────────────────────────────────────────────────
local function _saFindTarget()
    local bestPart, bestDist = nil, math.huge
    local cx = cam.ViewportSize.X / 2
    local cy = cam.ViewportSize.Y / 2

    local function check(char)
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then return end
        local sp, vis, z = cam:WorldToViewportPoint(part.Position)
        if not vis or z <= 0 then return end
        local d = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
        if d < _saFOV and d < bestDist then bestDist = d; bestPart = part end
    end

    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p ~= player then check(p.Character) end
    end
    local az = workspace:FindFirstChild("AiZones")
    if az then
        for _, zone in ipairs(az:GetChildren()) do
            for _, npc in ipairs(zone:GetChildren()) do
                if npc:IsA("Model") then check(npc) end
            end
        end
    end
    return bestPart
end

-- ── Prediction ────────────────────────────────────────────────────────────────
local function _saPredict(part)
    if not _saPrediction then return part.Position end
    local hrp = part.Parent and part.Parent:FindFirstChild("HumanoidRootPart")
    if not hrp then return part.Position end
    local vel  = hrp.AssemblyLinearVelocity
    local dist = (part.Position - cam.CFrame.Position).Magnitude
    local mv   = _getMuzzleVelocity()
    local tof  = dist / mv
    return Vector3.new(
        part.Position.X + vel.X * tof,
        part.Position.Y,
        part.Position.Z + vel.Z * tof
    )
end

-- ── Normal silent aim ─────────────────────────────────────────────────────────
-- Hooks RS.Modules.FPS.Bullet → CreateBullet(a, b, c, d, aim, e, ammo, tick, recoil)
-- arg5 (aim) = table with .CFrame → we replace aim.CFrame to face target
local function _hookNormal()
    if _saHooked then return end
    if not hookfunction or not newcclosure then
        EH_Notify("[SA] hookfunction unavailable on this executor", 5); return
    end
    pcall(function()
        local Bullet     = require(game:GetService("ReplicatedStorage").Modules.FPS.Bullet)
        local origCreate = Bullet.CreateBullet
        if not origCreate then
            EH_Notify("[SA] CreateBullet not found", 5); return
        end
        _saOrigCB = hookfunction(origCreate, newcclosure(function(...)
            local args = table.pack(...)  -- preserves nil args and exact count
            -- arg5 (aim) = table with .CFrame per spec
            if _saActive and _saMode == "normal" then
                local target = _saFindTarget()
                local aim = args[5]
                if target and aim and type(aim) == "table" and aim.CFrame then
                    _saLockTarget = target
                    local pos = _saPredict(target)
                    aim.CFrame = CFrame.new(aim.CFrame.Position, pos)
                end
            end
            return _saOrigCB(table.unpack(args, 1, args.n))
        end))
        _saHooked = true
        EH_Notify("[SA] normal silent hooked", 3)
    end)
    if not _saHooked then EH_Notify("[SA] hook failed", 5) end
end

-- ── Perfect silent aim ────────────────────────────────────────────────────────
-- __namecall hook handling 3 intercepts:
--   1. workspace:Raycast           → return fake hit at target
--   2. ProjectileInflict:FireServer → fix tick timestamp
--   3. obj:GetAttribute("ProjectileDrop"/"Drag") → return 0
local function _hookPerfect()
    if _saNCHooked then return end
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        _saInflictRem = RS.Remotes:FindFirstChild("ProjectileInflict")
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        local old = mt.__namecall
        _saOldNC = old
        mt.__namecall = newcclosure(function(self, ...)
            if checkcaller() then return old(self, ...) end
            local method = getnamecallmethod()
            local args   = {...}

            -- 1. Fake Raycast hit
            if method == "Raycast" and self == workspace and _saActive and _saMode == "perfect" then
                local target = _saLockTarget or _saFindTarget()
                if target then
                    local pos = _saPredict(target)
                    return {
                        Instance = target,
                        Position = pos,
                        Normal   = Vector3.new(0,1,0),
                        Material = Enum.Material.SmoothPlastic,
                        Distance = (pos - cam.CFrame.Position).Magnitude,
                    }
                end
            end

            -- 2. Fix ProjectileInflict tick
            -- FireServer(hitPart, hitPos, bulletId, tick, damage)
            if method == "FireServer" and _saInflictRem and self == _saInflictRem
               and _saActive and _saMode == "perfect" then
                local target = _saLockTarget or _saFindTarget()
                if target then
                    local hitPos     = _saPredict(target)
                    local dist       = (hitPos - cam.CFrame.Position).Magnitude
                    local travelTime = dist / _getMuzzleVelocity()
                    args[1] = target           -- hitPart
                    args[2] = hitPos           -- hitPos
                    -- args[4] = tick: add travel time so server anti-cheat accepts it
                    if args[4] then args[4] = args[4] + travelTime end
                    return old(self, table.unpack(args))
                end
            end

            -- 3. Zero out ProjectileDrop and Drag
            if method == "GetAttribute" and _saActive and _saMode == "perfect" then
                local attr = args[1]
                if attr == "ProjectileDrop" or attr == "Drag" then return 0 end
            end

            return old(self, ...)
        end)
        setreadonly(mt, true)
        _saNCHooked = true
        EH_Notify("[SA] perfect silent hooked", 3)
    end)
end

local function _unhookPerfect()
    if not _saOldNC then return end
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        mt.__namecall = _saOldNC
        setreadonly(mt, true)
    end)
    _saOldNC   = nil
    _saNCHooked = false
end

