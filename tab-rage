-- ─── no sway ──────────────────────────────────────────────────────
do
    local _swayEnabled = false
    local _swayPatched = false

    local function _patchSway()
        if _swayPatched then return end
        pcall(function()
            local rs = ReplicatedStorage
            local success, mod = pcall(require, rs:FindFirstChild("Modules") and rs.Modules:FindFirstChild("FPS"))
            if success and mod and mod.updateClient then
                local old_update = mod.updateClient
                mod.updateClient = function(a1, a2, a3)
                    local r1, r2, r3 = old_update(a1, a2, a3)
                    if _swayEnabled and a1 and a1.springs then
                        for _, spring in pairs(a1.springs) do
                            if spring.Position then spring.Position = Vector3.new() end
                            if spring.Speed then spring.Speed = 0 end
                        end
                    end
                    return r1, r2, r3
                end
                _swayPatched = true
            end
        end)
    end

    WeapSection:Toggle({Title = "no sway", Flag = "WepNoSway", Default = false, Callback = function(s)
        _swayEnabled = s
        if s then task.spawn(_patchSway) end
    end})
end

-- ─── unlock firemodes ─────────────────────────────────────────────
do
    local _fmEnabled = false
    local _fmModules = {}
    local _fmOriginals = {}
    local _fmCached = false

    local function _fmCache()
        table.clear(_fmModules); table.clear(_fmOriginals); _fmCached = false
        local items = ReplicatedStorage:FindFirstChild("ItemsList")
        if not items then return end
        for _, v in ipairs(items:GetDescendants()) do
            if v:IsA("ModuleScript") and v.Name == "SettingsModule" then
                local ok, mod = pcall(require, v)
                if ok and type(mod) == "table" then
                    _fmModules[#_fmModules+1] = mod
                    if type(mod.FireModes) == "table" then
                        local copy = {}
                        for i, m in ipairs(mod.FireModes) do copy[i] = m end
                        _fmOriginals[mod] = copy
                    end
                end
            end
        end
        _fmCached = true
    end

    WeapSection:Toggle({Title = "unlock firemodes", Flag = "WepUnlockFiremodes", Default = false, Callback = function(s)
        _fmEnabled = s
        if s then
            if not _fmCached then task.spawn(_fmCache) end
            task.spawn(function()
                if not _fmCached then task.wait(1) end
                for _, mod in ipairs(_fmModules) do
                    pcall(function() mod.FireModes = {"Auto","Semi"} end)
                end
            end)
        else
            for mod, modes in pairs(_fmOriginals) do
                pcall(function() mod.FireModes = modes end)
            end
        end
    end})
end

-- ─── rpm booster ──────────────────────────────────────────────────
do
    local _rpmEnabled = false
    local _rpmInterval = 0.05
    local _rpmModules = {}
    local _rpmOrig = {}

    local function _rpmCache()
        table.clear(_rpmModules); table.clear(_rpmOrig)
        local items = ReplicatedStorage:FindFirstChild("ItemsList")
        if not items then return end
        for _, v in ipairs(items:GetDescendants()) do
            if v:IsA("ModuleScript") and v.Name == "SettingsModule" then
                local ok, mod = pcall(require, v)
                if ok and type(mod) == "table" and type(mod.FireRate) == "number" then
                    _rpmModules[#_rpmModules+1] = mod
                    _rpmOrig[mod] = mod.FireRate
                end
            end
        end
    end

    local function _rpmApply()
        for _, mod in ipairs(_rpmModules) do
            pcall(function() mod.FireRate = _rpmInterval end)
        end
    end

    local function _rpmRestore()
        for mod, rate in pairs(_rpmOrig) do
            pcall(function() mod.FireRate = rate end)
        end
    end

    WeapSection:Toggle({Title = "rpm booster", Flag = "WepRPMBoost", Default = false, Callback = function(s)
        _rpmEnabled = s
        if s then task.spawn(function() _rpmCache(); _rpmApply() end)
        else _rpmRestore() end
    end})
    WeapSection:Slider({Title = "firerate (lower = faster)", Flag = "WepRPMVal", Symbol = "", Default = 5, Min = 0, Max = 10, Decimals = 2, Callback = function(v)
        _rpmInterval = v / 100
        if _rpmEnabled then _rpmApply() end
    end})
end



